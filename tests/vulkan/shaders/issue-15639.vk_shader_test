[compute shader]
#version 450
layout(local_size_x = 1) in;
layout(binding = 0) buffer B { int v; };

// Based on https://gitlab.freedesktop.org/mesa/mesa/-/work_items/15639
// invalid constant combining for Intel GPUs.

const int INT32_MIN = -2147483648;

void main()
{
  uint i = gl_GlobalInvocationID.x;

  // Intel SHL src0 cannot be immediate, so 0x00000001 goes in a register.
  int one = 1 << int(i & 3u);

  // SEL cannot keep both values immediate. 0x80000001 would be made by
  // reusing 0x00000001 with a float negate modifier.
  //
  // But 0x00000001 is subnormal, so float negation may flush it instead of
  // preserving payload bits.
  int selected = (i == 0u) ? INT32_MIN + 1 : 2;

  v = selected + one;
}

[test]
ssbo 0 4
compute 1 1 1
probe ssbo int 0 0 == -2147483646
