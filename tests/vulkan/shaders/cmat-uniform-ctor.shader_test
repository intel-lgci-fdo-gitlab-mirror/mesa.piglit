[require]
VK_KHR_storage_buffer_storage_class
vulkanMemoryModel
shaderFloat16
cooperative_matrix m=8 n=16 k=16 a=float16_t b=float16_t c=float result=float

[compute shader]
#version 450

#extension GL_KHR_shader_subgroup_basic: require
#extension GL_KHR_memory_scope_semantics: require
#extension GL_KHR_cooperative_matrix: require
#extension GL_EXT_shader_explicit_arithmetic_types_float16: require

#define M 8
#define N 16
#define K 16

layout(local_size_x = 32) in;
layout(binding = 0) readonly buffer Input { float bias[]; } in_data;
layout(binding = 1) writeonly buffer R { float r[]; };

void main() {
    coopmat<float16_t, gl_ScopeSubgroup, M, K, gl_MatrixUseA> matA =
        coopmat<float16_t, gl_ScopeSubgroup, M, K, gl_MatrixUseA>(float16_t(1.0));
    coopmat<float16_t, gl_ScopeSubgroup, K, N, gl_MatrixUseB> matB =
        coopmat<float16_t, gl_ScopeSubgroup, K, N, gl_MatrixUseB>(float16_t(1.0));
    coopmat<float, gl_ScopeSubgroup, M, N, gl_MatrixUseAccumulator> acc =
        coopmat<float, gl_ScopeSubgroup, M, N, gl_MatrixUseAccumulator>(in_data.bias[0]);

    acc = coopMatMulAdd(matA, matB, acc);
    coopMatStore(acc, r, 0, N, gl_CooperativeMatrixLayoutRowMajor);
}

[test]
# A and B are all ones, so A*B is 16.  The accumulator is initialized
# from a dynamically-uniform value loaded from an SSBO, so every result
# element is 17.
ssbo 0 subdata float 0 1.0
ssbo 1 512
compute 1 1 1
probe ssbo float 1 0 == 17.0
probe ssbo float 1 508 == 17.0
