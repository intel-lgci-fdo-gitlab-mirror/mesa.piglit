# This tests unrolling of a loop with two exit points where the trip count
# of both exits is unknown but we can estimate loop length via array access.
# The loop induction variable starts at 1 rather than 0; this exercises the
# OOB removal path that enables the residual loop to be eliminated.
[require]
GLSL >= 1.10

[vertex shader]
uniform int n_stop;
uniform float stops[18];

void main()
{
  gl_Position = gl_Vertex;

  vec4 colour = vec4(1.0, 1.0, 1.0, 1.0);

  int i;
  for (i = 1; i < n_stop; i++) {
    if (0.0 < stops[i])
        break;
  }

  if (i == 1)
     colour = vec4(0.0, 1.0, 0.0, 1.0);
  else if (i == 2)
     colour = vec4(1.0, 0.0, 0.0, 1.0);
  else if (i == 3)
     colour = vec4(0.0, 0.0, 1.0, 1.0);

  gl_FrontColor = colour;
}

[fragment shader]
void main()
{
  gl_FragColor = gl_Color;
}

[test]
clear color 0.5 0.5 0.5 0.5

# loop never runs (n_stop <= 1), i stays at 1
uniform int n_stop 1
draw rect -1 -1 2 2
probe all rgba 0.0 1.0 0.0 1.0

# break at i=1 (first iteration)
uniform int n_stop 3
uniform float stops[1] 1.0
draw rect -1 -1 2 2
probe all rgba 0.0 1.0 0.0 1.0

# no break at i=1, break at i=2
uniform int n_stop 3
uniform float stops[1] 0.0
uniform float stops[2] 1.0
draw rect -1 -1 2 2
probe all rgba 1.0 0.0 0.0 1.0

# break at i=2 even with larger n_stop
uniform int n_stop 4
uniform float stops[1] 0.0
uniform float stops[2] 1.0
draw rect -1 -1 2 2
probe all rgba 1.0 0.0 0.0 1.0

# break at i=3
uniform int n_stop 4
uniform float stops[1] 0.0
uniform float stops[2] 0.0
uniform float stops[3] 1.0
draw rect -1 -1 2 2
probe all rgba 0.0 0.0 1.0 1.0

# no break, loop exhausted (i=4)
uniform int n_stop 4
uniform float stops[1] 0.0
uniform float stops[2] 0.0
uniform float stops[3] 0.0
draw rect -1 -1 2 2
probe all rgba 1.0 1.0 1.0 1.0

# no break, loop exhausted (i=5)
uniform int n_stop 5
uniform float stops[1] 0.0
uniform float stops[2] 0.0
uniform float stops[3] 0.0
uniform float stops[4] 0.0
draw rect -1 -1 2 2
probe all rgba 1.0 1.0 1.0 1.0
